# ============================================================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================================================
# 
# LOCAL DEVELOPMENT:
# - Kosongkan VITE_API_URL untuk menggunakan Vite proxy ke backend lokal (:8000)
# - Vercel akan secara otomatis mengatur proxy di vite.config.js
#
# PRODUCTION (Vercel):
# - Set VITE_API_URL ke URL backend publik (Railway, Render, atau server sendiri)
# - Contoh: https://toko-api.railway.app
# - Set di Vercel Dashboard > Project Settings > Environment Variables

# Backend API URL (kosongkan untuk development lokal)
VITE_API_URL=

# Base path (biasanya kosong untuk deployment di Vercel root)
# VITE_BASE=/
