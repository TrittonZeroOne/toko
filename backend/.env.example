APP_PORT=8000
JWT_SECRET=ganti-dengan-string-panjang-acak-minimal-32-karakter

# Folder penyimpanan gambar produk (relatif ke cwd backend atau path absolut)
UPLOAD_DIR=uploads

# Supabase/PostgreSQL.
DB_DRIVER=postgres
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
DB_SSLMODE=require
DB_TIMEZONE=Asia/Jakarta

# Alternatif jika tidak memakai DATABASE_URL:
# DB_HOST=db.PROJECT_REF.supabase.co
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=isi_password_database_supabase
# DB_NAME=postgres

# MySQL lokal Laragon jika ingin dipakai lagi:
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=toko

# Supabase API keys (opsional, untuk fitur yang memakai Supabase REST/Auth/Storage).
# Backend database login tetap memakai DATABASE_URL di atas.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=product-images

MIDTRANS_MERCHANT_ID=M000000000
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false
# true = production, false = sandbox.
# Pastikan client/server key dari mode yang sama.
# URL publik backend untuk callback Midtrans. Contoh: https://xxxx.ngrok-free.app
APP_PUBLIC_URL=
# URL frontend untuk redirect setelah selesai / batal bayar Midtrans.
FRONTEND_PUBLIC_URL=http://localhost:5173
# Pisahkan dengan koma jika ada lebih dari satu domain frontend.
# Contoh: https://nama-project.vercel.app,https://www.domain-anda.com
CORS_ALLOWED_ORIGINS=
APP_NAME=Toko
# Opsional kalau ingin override URL callback satu per satu
MIDTRANS_NOTIFY_URL=
MIDTRANS_RETURN_URL=http://localhost:5173/orders
MIDTRANS_CANCEL_URL=http://localhost:5173/orders

# SMTP untuk email verifikasi dan OTP lupa password.
# Utamakan Resend. Jika RESEND_API_KEY kosong, backend fallback ke SMTP.
RESEND_API_KEY=
RESEND_FROM=Toko <onboarding@resend.dev>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# API wilayah Indonesia + cek ongkir
BINDERBYTE_API_KEY=
# Origin ongkir Binderbyte. Contoh: jakarta atau kebayoranbaru,jakarta.
# Jika kosong, backend memakai alamat admin dari database.
BINDERBYTE_ORIGIN=jakarta
# Instruksi transfer bank (tampil di checkout metode transfer manual). Bisa multi-baris.
# BANK_TRANSFER_NOTE=Transfer ke BCA 1234567890 a.n. Toko ...
