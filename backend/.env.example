APP_PORT=8000
JWT_SECRET=ganti-dengan-string-panjang-acak-minimal-32-karakter

# ============================================================================
# FILE UPLOADS
# ============================================================================
# Folder penyimpanan gambar produk
# Development: uploads (relatif)
# Production/Vercel: gunakan Supabase Storage (SUPABASE_STORAGE_BUCKET)
UPLOAD_DIR=uploads

# ============================================================================
# DATABASE - Supabase PostgreSQL
# ============================================================================
# Recommended untuk production: gunakan DATABASE_URL lengkap
# Dari Supabase > Project Settings > Database > Connection string
DB_DRIVER=postgres
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
DB_SSLMODE=require
DB_TIMEZONE=Asia/Jakarta

# Alternatif jika tidak memakai DATABASE_URL (untuk local dev):
# DB_HOST=db.PROJECT_REF.supabase.co
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=isi_password_database_supabase
# DB_NAME=postgres

# ============================================================================
# SUPABASE - API & STORAGE
# ============================================================================
# Opsional: Supabase Storage untuk upload file (recommended daripada lokal)
# Dari Supabase > Project Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=product-images

# ============================================================================
# PAYMENT GATEWAY - MIDTRANS
# ============================================================================
# Dari Midtrans > Settings > Access Keys
MIDTRANS_MERCHANT_ID=M000000000
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# URLs untuk callback dan redirect Midtrans
# APP_PUBLIC_URL: URL backend publik (untuk Midtrans webhook callback)
# FRONTEND_PUBLIC_URL: URL frontend publik (untuk redirect setelah bayar)
APP_PUBLIC_URL=https://your-backend-url.railway.app
FRONTEND_PUBLIC_URL=https://your-frontend-url.vercel.app

# URLs callback Midtrans (opsional, jika ingin custom)
MIDTRANS_NOTIFY_URL=https://your-backend-url.railway.app/api/midtrans-webhook
MIDTRANS_RETURN_URL=https://your-frontend-url.vercel.app/orders
MIDTRANS_CANCEL_URL=https://your-frontend-url.vercel.app/orders

# CORS - domain frontend yang diizinkan (comma-separated)
# CORS_ALLOWED_ORIGINS=https://your-frontend-url.vercel.app,https://www.domain-anda.com

# Instruksi transfer bank (tampil di checkout metode transfer manual)
# BANK_TRANSFER_NOTE=Transfer ke BCA 1234567890 a.n. Toko Anda...

# ============================================================================
# EMAIL SERVICE
# ============================================================================
# Pilih satu:
# 1. RESEND (recommended, modern) - setup lebih mudah di cloud
RESEND_API_KEY=
RESEND_FROM=Toko <onboarding@resend.dev>

# 2. SMTP (fallback)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ============================================================================
# SHIPPING & LOGISTICS - BINDERBYTE
# ============================================================================
# API untuk cek ongkir dan wilayah Indonesia
# https://docs.binderbyte.com/
BINDERBYTE_API_KEY=
BINDERBYTE_ORIGIN=jakarta

# ============================================================================
# APP CONFIG
# ============================================================================
APP_NAME=Toko
