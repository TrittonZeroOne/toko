APP_PORT=8000
JWT_SECRET=ganti-dengan-string-panjang-acak-minimal-32-karakter
UPLOAD_DIR=uploads

# Database Supabase PostgreSQL.
# Ambil dari Supabase: Project Settings > Database > Connection string.
DB_DRIVER=postgres
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
DB_SSLMODE=require
DB_TIMEZONE=Asia/Jakarta

# Alternatif jika tidak memakai DATABASE_URL:
# DB_HOST=db.PROJECT_REF.supabase.co
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=isi_password_database_supabase
# DB_NAME=postgres

# Supabase API keys.
# Ambil dari Supabase: Project Settings > API.
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=isi_anon_key
SUPABASE_SERVICE_KEY=isi_service_role_key
SUPABASE_STORAGE_BUCKET=product-images

MIDTRANS_MERCHANT_ID=M000000000
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false
APP_PUBLIC_URL=
FRONTEND_PUBLIC_URL=http://localhost:5173
APP_NAME=Toko
MIDTRANS_NOTIFY_URL=
MIDTRANS_RETURN_URL=http://localhost:5173/orders
MIDTRANS_CANCEL_URL=http://localhost:5173/orders

RESEND_API_KEY=
RESEND_FROM=Toko <onboarding@resend.dev>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

BINDERBYTE_API_KEY=
# Origin ongkir Binderbyte. Contoh: jakarta atau kebayoranbaru,jakarta.
# Jika kosong, backend memakai alamat admin dari database.
BINDERBYTE_ORIGIN=jakarta
# BANK_TRANSFER_NOTE=Transfer ke BCA 1234567890 a.n. Toko ...
